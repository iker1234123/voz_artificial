import os
import tempfile
import urllib.request
import urllib.parse
import json
import pygame
from gtts import gTTS

GEMINI_API_KEY = "AIzaSyByqyuaakR5GYL7-XUgNK2mf1374bxBFfQ"

def obtener_respuesta(historial):
    url = f"https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key={GEMINI_API_KEY}"
    
    partes = [{"role": m["role"], "parts": [{"text": m["text"]}]} for m in historial]
    data = json.dumps({"contents": partes}).encode("utf-8")
    
    req = urllib.request.Request(url, data=data, headers={"Content-Type": "application/json"})
    with urllib.request.urlopen(req) as resp:
        resultado = json.loads(resp.read())
    
    return resultado["candidates"][0]["content"]["parts"][0]["text"]

def hablar(texto):
    pygame.mixer.init()
    with tempfile.NamedTemporaryFile(suffix=".mp3", delete=False) as f:
        tmp = f.name
    tts = gTTS(texto, lang="es")
    tts.save(tmp)
    pygame.mixer.music.load(tmp)
    pygame.mixer.music.play()
    while pygame.mixer.music.get_busy():
        pygame.time.Clock().tick(10)
    pygame.mixer.music.unload()
    os.remove(tmp)

def main():
    print("Bot de voz listo. Escribe tu mensaje (o 'salir').\n")
    historial = []

    while True:
        entrada = input("Tú: ").strip()
        if not entrada:
            continue
        if entrada.lower() in ("salir", "exit"):
            hablar("¡Hasta luego!")
            break

        historial.append({"role": "user", "text": entrada})

        print("Pensando...")
        try:
            respuesta = obtener_respuesta(historial)
        except Exception as e:
            print(f"❌ Error: {e}")
            historial.pop()
            continue

        historial.append({"role": "model", "text": respuesta})
        print(f"Bot: {respuesta}\n")
        hablar(respuesta)

if __name__ == "__main__":
    main()
