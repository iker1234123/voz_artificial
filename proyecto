import os
import sys
import anthropic
from gtts import gTTS
import pygame
import tempfile
 
# ── Configuración ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY = os.getenv("ANTHROPIC_API_KEY", "")
SYSTEM_PROMPT = "Eres un asistente amigable que responde en español de forma concisa y clara."
 
# ── Audio ──────────────────────────────────────────────────────────────────────
def hablar(texto: str):
    """Convierte texto a voz y lo reproduce."""
    pygame.mixer.init()
    with tempfile.NamedTemporaryFile(suffix=".mp3", delete=False) as f:
        tmp_path = f.name
 
    try:
        tts = gTTS(texto, lang="es")
        tts.save(tmp_path)
        pygame.mixer.music.load(tmp_path)
        pygame.mixer.music.play()
        while pygame.mixer.music.get_busy():
            pygame.time.Clock().tick(10)
    finally:
        pygame.mixer.music.unload()
        os.remove(tmp_path)
 
# ── IA ─────────────────────────────────────────────────────────────────────────
def obtener_respuesta(historial: list[dict]) -> str:
    """Llama a la API de Claude y devuelve la respuesta."""
    client = anthropic.Anthropic(api_key=ANTHROPIC_API_KEY)
    mensaje = client.messages.create(
        model="claude-sonnet-4-20250514",
        max_tokens=300,
        system=SYSTEM_PROMPT,
        messages=historial,
    )
    return mensaje.content[0].text
 
# ── Loop principal ─────────────────────────────────────────────────────────────
def main():
    if not ANTHROPIC_API_KEY:
        print("❌  Falta la variable de entorno ANTHROPIC_API_KEY")
        sys.exit(1)
 
    print("🤖  Bot de voz iniciado. Escribe tu mensaje (o 'salir' para terminar).\n")
    historial = []
 
    while True:
        try:
            entrada = input("Tú: ").strip()
        except (KeyboardInterrupt, EOFError):
            print("\n👋  ¡Hasta luego!")
            break
 
        if not entrada:
            continue
        if entrada.lower() in ("salir", "exit", "quit"):
            print("👋  ¡Hasta luego!")
            hablar("¡Hasta luego!")
            break
 
        historial.append({"role": "user", "content": entrada})
 
        print("🤔  Pensando...")
        try:
            respuesta = obtener_respuesta(historial)
        except Exception as e:
            print(f"❌  Error al contactar la API: {e}")
            historial.pop()
            continue
 
        historial.append({"role": "assistant", "content": respuesta})
 
        print(f"Bot: {respuesta}\n")
        hablar(respuesta)
 
if __name__ == "__main__":
    main()
